
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Comprehensive profile for all Edugo users with role-based attributes and approval status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["student", "faculty", "hod", "admin", "advisor"] },
        "department": { "type": "string", "enum": ["CSE", "ECE", "ME", "CE", "EEE"] },
        "isApproved": { "type": "boolean" },
        "collegeName": { "type": "string" },
        "rollNumber": { "type": "string", "description": "Student only" },
        "semester": { "type": "string", "description": "Student only" },
        "subject": { "type": "string", "description": "Faculty only" },
        "designation": { "type": "string", "description": "HOD only" },
        "assignedBatch": { "type": "string", "description": "Advisor only" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "email", "role", "department"]
    },
    "AttendanceLog": {
      "title": "Attendance Log",
      "description": "Records of RFID or AI-based attendance marks.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "subjectId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "method": { "type": "string", "enum": ["rfid", "p2net", "manual"] },
        "status": { "type": "string", "enum": ["present", "absent", "late"] },
        "markedBy": { "type": "string", "description": "UID of faculty who marked manually, or 'system'" }
      }
    },
    "Department": {
      "title": "Department",
      "description": "Academic department metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "hodUid": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and approval state."
    },
    "/attendance/{logId}": {
      "schema": "AttendanceLog",
      "description": "Global attendance records."
    },
    "/departments/{deptId}": {
      "schema": "Department",
      "description": "Department definitions and HOD mapping."
    }
  }
}
