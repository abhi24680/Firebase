# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000

# Google GenAI (Genkit)
GOOGLE_GENAI_API_KEY=your-genai-api-key

# Firebase Admin SDK (Service Account)
# Provide the full JSON as a string, or base64-encoded
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Emulator mode (set to "true" for local Docker development)
NEXT_PUBLIC_USE_EMULATOR=true
NEXT_PUBLIC_EMULATOR_HOST=localhost
FIREBASE_EMULATOR_HOST=localhost:9099
